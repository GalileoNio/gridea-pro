<script src="/scripts/transliteration.umd.min.js"></script>
<script type="application/javascript">

if (window.hljs && typeof window.hljs.highlightAll === 'function') {
  window.hljs.highlightAll()
} else if (window.hljs && typeof window.hljs.initHighlightingOnLoad === 'function') {
  window.hljs.initHighlightingOnLoad()
}

var app = new Vue({
  el: '#app',
  data: {
    menuVisible: false,
  },
})

;(function () {
  var searchToggle = document.querySelector('[data-search-toggle]')
  var searchContainer = document.querySelector('[data-search-container]')
  var searchClose = document.querySelector('[data-search-close]')
  var searchInput = document.getElementById('search-input')
  var searchResults = document.getElementById('search-results')
  var searchIndex = []
  var searchLoaded = false
  var searchLoading = false

  if (!searchToggle || !searchContainer || !searchInput || !searchResults) {
    return
  }

  function openSearch() {
    searchContainer.classList.add('is-active')
    if (app) {
      app.menuVisible = false
    }
    loadSearchIndex()
    setTimeout(function () {
      searchInput.focus()
    }, 0)
  }

  function closeSearch() {
    searchContainer.classList.remove('is-active')
  }

  function loadSearchIndex() {
    if (searchLoaded || searchLoading) {
      return
    }

    searchLoading = true
    renderSearchMessage('正在搜索...')
    fetch('/api/search.json')
      .then(function (response) {
        if (!response.ok) {
          throw new Error('Failed to load search index')
        }
        return response.json()
      })
      .then(function (posts) {
        searchIndex = Array.isArray(posts) ? posts : []
        buildPinyinSearchIndex()
        searchLoaded = true
        searchPosts()
      })
      .catch(function () {
        renderSearchMessage('搜索数据加载失败')
      })
      .finally(function () {
        searchLoading = false
      })
  }

  function searchPosts() {
    var query = searchInput.value.trim().toLowerCase()
    var compactQuery = compactSearchText(query)

    if (!query) {
      renderSearchMessage('输入关键词开始搜索')
      return
    }

    if (!searchLoaded) {
      renderSearchMessage('正在搜索...')
      return
    }

    var results = searchIndex
      .map(function (post) {
        return scoreSearchPost(post, query, compactQuery)
      })
      .filter(function (result) {
        return result.score > 0
      })
      .sort(function (a, b) {
        return b.score - a.score
      })
      .slice(0, 10)

    if (!results.length) {
      renderSearchMessage('没有找到相关文章')
      return
    }

    searchResults.innerHTML = results.map(function (result) {
      var post = result.post
      var title = highlightSearchText(post.title || '', query)
      var content = highlightSearchText(createSearchExcerpt(post.content || '', query, result.contentIndex), query)
      return '<a class="search-result" href="' + escapeAttribute(post.link || '#') + '">' +
        '<div class="search-result-title">' + title + '</div>' +
        '<div class="search-result-content">' + content + '</div>' +
      '</a>'
    }).join('')
  }

  function renderSearchMessage(message) {
    searchResults.innerHTML = '<div class="search-empty">' + escapeHtml(message) + '</div>'
  }

  function createSearchExcerpt(content, query, knownIndex) {
    var lowerContent = content.toLowerCase()
    var index = typeof knownIndex === 'number' ? knownIndex : lowerContent.indexOf(query)

    if (index === -1) {
      return content.slice(0, 120)
    }

    var start = Math.max(index - 45, 0)
    var end = Math.min(index + query.length + 75, content.length)
    return (start > 0 ? '...' : '') + content.slice(start, end) + (end < content.length ? '...' : '')
  }

  function highlightSearchText(text, query) {
    var escapedText = escapeHtml(text)
    var escapedQuery = escapeRegExp(query)
    return escapedText.replace(new RegExp('(' + escapedQuery + ')', 'ig'), '<mark>$1</mark>')
  }

  function scoreSearchPost(post, query, compactQuery) {
    var title = (post.title || '').toLowerCase()
    var content = (post.content || '').toLowerCase()
    var tags = ((post.tags || []).join(' ')).toLowerCase()
    var contentIndex = content.indexOf(query)
    var score = 0

    if (title.indexOf(query) > -1) {
      score += 100
    }
    if (tags.indexOf(query) > -1) {
      score += 70
    }
    if (contentIndex > -1) {
      score += 20
    }

    if (compactQuery && post._pinyinSearch) {
      if (post._pinyinSearch.title.indexOf(query) > -1 || post._pinyinSearch.titleCompact.indexOf(compactQuery) > -1) {
        score += 90
      }
      if (post._pinyinSearch.titleInitials.indexOf(compactQuery) > -1) {
        score += 75
      }
      if (post._pinyinSearch.tags.indexOf(query) > -1 || post._pinyinSearch.tagsCompact.indexOf(compactQuery) > -1) {
        score += 60
      }
      if (post._pinyinSearch.tagsInitials.indexOf(compactQuery) > -1) {
        score += 45
      }
      if (post._pinyinSearch.content.indexOf(query) > -1 || post._pinyinSearch.contentCompact.indexOf(compactQuery) > -1) {
        score += 10
      }
      if (post._pinyinSearch.contentInitials.indexOf(compactQuery) > -1) {
        score += 6
      }
    }

    return {
      post: post,
      score: score,
      contentIndex: contentIndex,
    }
  }

  function buildPinyinSearchIndex() {
    searchIndex.forEach(function (post) {
      if (post._pinyinSearch) {
        return
      }

      var tagText = (post.tags || []).join(' ')
      post._pinyinSearch = {
        title: toPinyinWords(post.title || ''),
        titleCompact: toPinyinCompact(post.title || ''),
        titleInitials: toPinyinInitials(post.title || ''),
        tags: toPinyinWords(tagText),
        tagsCompact: toPinyinCompact(tagText),
        tagsInitials: toPinyinInitials(tagText),
        content: toPinyinWords(post.content || ''),
        contentCompact: toPinyinCompact(post.content || ''),
        contentInitials: toPinyinInitials(post.content || ''),
      }
    })
  }

  function toPinyinWords(text) {
    return transliterateText(text)
  }

  function toPinyinCompact(text) {
    return compactSearchText(transliterateText(text))
  }

  function toPinyinInitials(text) {
    return transliterateText(text)
      .split(/\s+/)
      .map(function (word) {
        return word.charAt(0)
      })
      .join('')
  }

  function transliterateText(text) {
    if (!window.transliteration || typeof window.transliteration.transliterate !== 'function') {
      return ''
    }

    return window.transliteration.transliterate(String(text || ''))
      .replace(/([a-z])([A-Z])/g, '$1 $2')
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, ' ')
      .replace(/\s+/g, ' ')
      .trim()
  }

  function compactSearchText(text) {
    return String(text || '').toLowerCase().replace(/[^a-z0-9]+/g, '')
  }

  function escapeHtml(text) {
    return String(text)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;')
  }

  function escapeAttribute(text) {
    return escapeHtml(text).replace(/`/g, '&#096;')
  }

  function escapeRegExp(text) {
    return String(text).replace(/[.*+?^${}()|[\]\\]/g, '\\$&')
  }

  searchToggle.addEventListener('click', openSearch)
  if (searchClose) {
    searchClose.addEventListener('click', closeSearch)
  }
  searchContainer.addEventListener('click', function (event) {
    if (event.target === searchContainer) {
      closeSearch()
    }
  })
  searchInput.addEventListener('input', searchPosts)
  document.addEventListener('keydown', function (event) {
    if (event.key === 'Escape') {
      closeSearch()
    }
  })
})()

;(function () {
  var scrollTopButton = document.querySelector('[data-scroll-top]')
  if (!scrollTopButton) {
    return
  }

  scrollTopButton.addEventListener('click', function () {
    window.scrollTo({
      top: 0,
      behavior: 'smooth',
    })
  })
})()

;(function () {
  var shareButton = document.querySelector('[data-post-share]')
  var bookmarkButton = document.querySelector('[data-post-bookmark]')
  var bookmarkKey = 'fly:bookmarked:' + window.location.pathname

  if (shareButton) {
    var sharePopover = null

    function setShareFeedback(success) {
      shareButton.classList.toggle('is-copied', success)
      shareButton.setAttribute('aria-label', success ? '链接已复制' : '分享文章')
      shareButton.setAttribute('title', success ? '链接已复制' : '分享文章')

      if (success) {
        setTimeout(function () {
          shareButton.classList.remove('is-copied')
          shareButton.setAttribute('aria-label', '分享文章')
          shareButton.setAttribute('title', '分享文章')
        }, 1600)
      }
    }

    function closeSharePopover() {
      if (sharePopover && sharePopover.parentNode) {
        sharePopover.parentNode.removeChild(sharePopover)
      }
      sharePopover = null
    }

    function openSharePopover(url) {
      closeSharePopover()

      sharePopover = document.createElement('div')
      sharePopover.className = 'post-share-popover'
      var inner = document.createElement('div')
      var closeButton = document.createElement('button')
      var label = document.createElement('label')
      var input = document.createElement('input')

      inner.className = 'post-share-popover-inner'
      closeButton.className = 'post-share-popover-close'
      closeButton.type = 'button'
      closeButton.setAttribute('aria-label', '关闭')
      closeButton.textContent = '×'
      label.className = 'post-share-popover-label'
      label.textContent = '复制文章链接'
      input.className = 'post-share-popover-input'
      input.type = 'text'
      input.readOnly = true
      input.value = url

      inner.appendChild(closeButton)
      inner.appendChild(label)
      inner.appendChild(input)
      sharePopover.appendChild(inner)
      document.body.appendChild(sharePopover)

      if (input) {
        input.focus()
        input.select()
      }
      if (closeButton) {
        closeButton.addEventListener('click', closeSharePopover)
      }
      sharePopover.addEventListener('click', function (event) {
        if (event.target === sharePopover) {
          closeSharePopover()
        }
      })
    }

    function fallbackCopyLink() {
      var url = window.location.href

      if (navigator.clipboard && navigator.clipboard.writeText) {
        return navigator.clipboard.writeText(url)
          .then(function () {
            setShareFeedback(true)
            return true
          })
          .catch(function () {
            return copyLinkWithTextarea(url)
          })
      }

      return copyLinkWithTextarea(url)
    }

    function copyLinkWithTextarea(url) {
      var textarea = document.createElement('textarea')
      textarea.value = url
      textarea.setAttribute('readonly', '')
      textarea.style.position = 'fixed'
      textarea.style.left = '-9999px'
      textarea.style.top = '0'
      document.body.appendChild(textarea)
      textarea.focus()
      textarea.select()
      textarea.setSelectionRange(0, textarea.value.length)

      var copied = false
      try {
        copied = document.execCommand('copy')
      } catch (_) {
        copied = false
      }

      document.body.removeChild(textarea)
      setShareFeedback(copied)
      if (!copied) {
        openSharePopover(url)
      }
      return Promise.resolve(copied)
    }

    shareButton.addEventListener('click', function () {
      var shareData = {
        title: document.title,
        url: window.location.href,
      }

      if (navigator.share) {
        navigator.share(shareData).catch(function () {
          fallbackCopyLink()
        })
        return
      }

      fallbackCopyLink()
    })

    document.addEventListener('keydown', function (event) {
      if (event.key === 'Escape') {
        closeSharePopover()
      }
    })
  }

  if (bookmarkButton) {
    try {
      var bookmarked = localStorage.getItem(bookmarkKey) === '1'
      bookmarkButton.classList.toggle('is-active', bookmarked)
    } catch (_) {}

    bookmarkButton.addEventListener('click', function () {
      var nextState = !bookmarkButton.classList.contains('is-active')
      bookmarkButton.classList.toggle('is-active', nextState)
      try {
        if (nextState) {
          localStorage.setItem(bookmarkKey, '1')
        } else {
          localStorage.removeItem(bookmarkKey)
        }
      } catch (_) {}
    })
  }
})()

;(function () {
  var categoryButtons = Array.prototype.slice.call(document.querySelectorAll('[data-home-category-filter]'))
  var postItems = Array.prototype.slice.call(document.querySelectorAll('.home-posts .post-item'))
  var pagination = document.querySelector('.home-posts .pagination-container')
  var emptyState = document.querySelector('[data-home-filter-empty]')

  if (!categoryButtons.length || !postItems.length) {
    return
  }

  function setActiveButton(activeButton) {
    categoryButtons.forEach(function (button) {
      button.classList.toggle('is-active', button === activeButton)
    })
  }

  function filterPosts(categorySlug) {
    var visibleCount = 0

    postItems.forEach(function (item) {
      var slugs = (item.getAttribute('data-category-slugs') || '').split(/\s+/)
      var shouldShow = categorySlug === 'all' || slugs.indexOf(categorySlug) > -1
      item.style.display = shouldShow ? '' : 'none'
      if (shouldShow) {
        visibleCount += 1
      }
    })

    if (pagination) {
      pagination.style.display = categorySlug === 'all' ? '' : 'none'
    }

    if (emptyState) {
      emptyState.classList.toggle('is-active', visibleCount === 0)
    }
  }

  categoryButtons.forEach(function (button) {
    button.addEventListener('click', function () {
      setActiveButton(button)
      filterPosts(button.getAttribute('data-home-category-filter') || 'all')
    })
  })
})()

;(function () {
  var refreshButton = document.querySelector('[data-memo-refresh]')
  var memoItems = Array.prototype.slice.call(document.querySelectorAll('[data-memo-item]'))

  if (!refreshButton || memoItems.length <= 3) {
    return
  }

  function showMemos(indexes) {
    memoItems.forEach(function (item, index) {
      item.classList.toggle('is-hidden', indexes.indexOf(index) === -1)
    })
  }

  function pickRandomMemos() {
    var indexes = memoItems.map(function (_, index) {
      return index
    })

    for (var i = indexes.length - 1; i > 0; i -= 1) {
      var randomIndex = Math.floor(Math.random() * (i + 1))
      var current = indexes[i]
      indexes[i] = indexes[randomIndex]
      indexes[randomIndex] = current
    }

    showMemos(indexes.slice(0, 3))
  }

  refreshButton.addEventListener('click', pickRandomMemos)
})()

</script>

<% if (typeof commentSetting !== 'undefined' && commentSetting.showComment) { %>

  <% if (commentSetting.commentPlatform === 'gitalk') { %>
    <script src="https://unpkg.com/gitalk/dist/gitalk.min.js"></script>
    <script>

      var gitalk = new Gitalk({
        clientID: '<%= commentSetting.gitalkSetting.clientId %>',
        clientSecret: '<%= commentSetting.gitalkSetting.clientSecret %>',
        repo: '<%= commentSetting.gitalkSetting.repository %>',
        owner: '<%= commentSetting.gitalkSetting.owner %>',
        admin: ['<%= commentSetting.gitalkSetting.owner %>'],
        id: (location.pathname).substring(0, 49),      // Ensure uniqueness and length less than 50
        distractionFreeMode: false  // Facebook-like distraction free mode
      })

      gitalk.render('gitalk-container')

    </script>
  <% } %>

  <% if (commentSetting.commentPlatform === 'disqus') { %>
    <script src="https://unpkg.com/disqusjs@1.1/dist/disqus.js"></script>
    <script>

    var options = {
      shortname: '<%= commentSetting.disqusSetting.shortname %>',
      apikey: '<%= commentSetting.disqusSetting.apikey %>',
    }
    if ('<%= commentSetting.disqusSetting.api %>') {
      options.api = '<%= commentSetting.disqusSetting.api %>'
    }
    var dsqjs = new DisqusJS(options)

    </script>
  <% } %>

  <% if (['Giscus', 'giscus', 'Gitcus', 'gitcus'].includes(commentSetting.commentPlatform)) { %>
    <script>
      var giscusContainer = document.getElementById('giscus-container')

      if (giscusContainer) {
        var giscusScript = document.createElement('script')
        giscusScript.src = 'https://giscus.app/client.js'
        giscusScript.setAttribute('data-repo', '<%= commentSetting.repo %>')
        giscusScript.setAttribute('data-repo-id', '<%= commentSetting.repoId %>')
        giscusScript.setAttribute('data-category', '<%= commentSetting.category %>')
        giscusScript.setAttribute('data-category-id', '<%= commentSetting.categoryId %>')
        giscusScript.setAttribute('data-mapping', 'pathname')
        giscusScript.setAttribute('data-strict', '0')
        giscusScript.setAttribute('data-reactions-enabled', '1')
        giscusScript.setAttribute('data-emit-metadata', '0')
        giscusScript.setAttribute('data-input-position', 'top')
        giscusScript.setAttribute('data-theme', 'preferred_color_scheme')
        giscusScript.setAttribute('data-lang', 'zh-CN')
        giscusScript.crossOrigin = 'anonymous'
        giscusScript.async = true
        giscusContainer.appendChild(giscusScript)
      }
    </script>
  <% } %>

<% } %>
