
<!DOCTYPE html>
<%
  const postSlug = (post.link || '').split('/').filter(Boolean).pop() || '';
  const postAssetsPath = postSlug ? `/post/${postSlug}/${postSlug}.assets/` : '';
  const normalizePostImages = function(html) {
    if (!postAssetsPath) {
      return html || '';
    }
    return (html || '')
      .replace(/<img([^>]*?)src="post-images\/([^"]+)"([^>]*)>/g, function(match, before, fileName, after) {
        const attrs = after.replace(/\s*\/\s*$/, '');
        return `<img${before}src="${postAssetsPath}${fileName}"${attrs} onerror="this.onerror=null;this.src='/post-images/${fileName}'">`;
      })
      .replace(new RegExp(`<img([^>]*?)src="${postSlug}\\.assets\\/([^"]+)"([^>]*)>`, 'g'), function(match, before, fileName, after) {
        const attrs = after.replace(/\s*\/\s*$/, '');
        return `<img${before}src="${postAssetsPath}${fileName}"${attrs} onerror="this.onerror=null;this.src='/post-images/${fileName}'">`;
      });
  };
  const commentsEnabled = typeof commentSetting !== 'undefined' && commentSetting.showComment;
%>
<html>
  <head>
    <%- include('./includes/head', { siteTitle: `${post.title} | ${themeConfig.siteName}` }) %>
  </head>
  <body>
    <div id="app" class="main post-main">
      <%- include('./includes/header') %>

      <div class="content-container post-content-container">
        <div class="post-layout <%= commentsEnabled ? 'has-comment-sidebar' : '' %>">
          <main class="post-primary">
            <div class="post-detail">
              <% if (themeConfig.showFeatureImage && post.feature) { %>
                <div class="feature-container">
                  <img class="post-feature-image" src="<%= post.feature %>" alt="<%= post.title %>">
                </div>
              <% } %>
              <h2 class="post-title"><%= post.title %></h2>
              <div class="post-info post-detail-info">
                <span><i class="icon-calendar-outline"></i> <%= post.dateFormat %></span>
                <% if (post.tags.length > 0) { %>
                  <span>
                    <i class="icon-pricetags-outline"></i>
                    <% post.tags.forEach(function(tag, index) { %>
                      <a href="<%= tag.link %>">
                        <%= tag.name %>
                        <% if (index !== post.tags.length - 1) { %>
                          ，
                        <% } %>
                      </a>
                    <% }); %>
                  </span>
                <% } %>
              </div>
              <div class="post-content" v-pre>
                <%- normalizePostImages(post.content) %>
              </div>
            </div>

            <% if (post.nextPost && !post.hideInList) { %>
              <div class="next-post">
                <a class="purple-link" href="<%= post.nextPost.link %>">
                  <h3 class="post-title">
                    下一篇：<%= post.nextPost.title %>
                  </h3>
                </a>
              </div>
            <% } %>
          </main>

          <% if (commentsEnabled) { %>
            <aside class="post-comment-sidebar" aria-label="评论区">
              <div class="post-comment-sidebar-inner">
                <h2 class="post-comment-title">评论</h2>
                <% if (commentSetting.commentPlatform === 'gitalk') { %>
                  <div id="gitalk-container"></div>
                <% } %>

                <% if (['Giscus', 'giscus', 'Gitcus', 'gitcus'].includes(commentSetting.commentPlatform)) { %>
                  <section class="giscus-container">
                    <div id="giscus-container"></div>
                  </section>
                <% } %>

                <% if (commentSetting.commentPlatform === 'disqus') { %>
                  <div id="disqus_thread"></div>
                <% } %>
              </div>
            </aside>
          <% } %>
        </div>
      </div>

      <%- include('./includes/footer') %>

    </div>
    <%- include('./includes/scripts') %>
  </body>
</html>
